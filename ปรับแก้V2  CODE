   if(g_State == STATE_SWEEP_FOUND)
      timeoutStr = "BOS wait: " + IntegerToString(g_BarsAfterSweep) + "/" + IntegerToString(InpMaxBarsAfterSweep) + " bars";
   else if(g_State == STATE_BOS_FOUND)
      timeoutStr = "Retest wait: " + IntegerToString(g_BarsAfterBOS) + "/" + IntegerToString(InpMaxBarsAfterBOS) + " bars";
   else
      timeoutStr = "Timeout: n/a";
   CreateLabel("Timeout", timeoutStr, 20, 166, clrKhaki);
   CreateLabel("Spread",  "Spread : " + DoubleToString(spread, 0) + " pts",   20, 166,
               spread > InpMaxSpreadPts ? clrRed : clrLimeGreen);
   CreateLabel("Session", "Session: " + (IsInSession() ? "OPEN ✓" : "CLOSED ✗"),
               20, 184, IsInSession() ? clrLimeGreen : clrGray);

   ChartRedraw(0);
}

