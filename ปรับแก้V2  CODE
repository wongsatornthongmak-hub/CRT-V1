   CreateLabel("CRT_L",   "CRT Lo : " + DoubleToString(g_CRT_Low,  _Digits), 20, 112, clrSilver);
   CreateLabel("Sweep",   "Sweep  : " + DoubleToString(g_SweepPrice,_Digits), 20, 130, clrOrange);
   CreateLabel("BOS",     "BOS    : " + DoubleToString(g_BOS_Price, _Digits), 20, 148, clrAqua);
