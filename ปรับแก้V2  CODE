int CountPositions()
{
   int cnt = 0;
   for(int i = PositionsTotal() - 1; i >= 0; i--)
      if(posInfo.SelectByIndex(i))
         if(posInfo.Magic() == InpMagic && posInfo.Symbol() == _Symbol)
            cnt++;
   return cnt;
}

bool IsNewBar(ENUM_TIMEFRAMES tf)
{
   static datetime lastBar = 0;
   datetime curBar = iTime(_Symbol, tf, 0);
   if(curBar != lastBar) { lastBar = curBar; return true; }
   return false;
}

void SetSL(ulong ticket, double newSL)
{
   if(!posInfo.SelectByTicket(ticket)) return;
   double tp = posInfo.TakeProfit();
   trade.PositionModify(ticket, NormalizeDouble(newSL, _Digits), tp);
}

void ResetState()
{
   g_State          = STATE_IDLE;
   g_CRT_High       = 0;
   g_CRT_Low        = 0;
   g_CRT_Mid        = 0;
   g_SweepPrice     = 0;
   g_BOS_Price      = 0;
   g_BOS_High       = 0;
   g_BOS_Low        = 0;
   g_SL_Price       = 0;
   g_SL_Dist        = 0;
   g_BarsAfterSweep = 0;
   g_BarsAfterBOS   = 0;
}

bool IsTracked(ulong ticket)
{
   for(int i = 0; i < g_TradeCount; i++)
      if(g_Trades[i].ticket == ticket) return true;
   return false;
}

void AddTradeRecord(ulong ticket, double entry, double slDist, double totalLot)
{
   g_TradeCount++;
   ArrayResize(g_Trades, g_TradeCount);
   int idx               = g_TradeCount - 1;
   g_Trades[idx].ticket      = ticket;
   g_Trades[idx].entryPrice  = entry;
   g_Trades[idx].slDist      = slDist;
   g_Trades[idx].tp1Hit      = false;
   g_Trades[idx].tp2Hit      = false;
   g_Trades[idx].beSet       = false;
   g_Trades[idx].trailActive = false;
   g_Trades[idx].lotTP1      = NormalizeDouble(totalLot * InpTP1_Pct / 100.0, 2);
   g_Trades[idx].lotTP2      = NormalizeDouble(totalLot * InpTP2_Pct / 100.0, 2);
}

void CleanClosedTrades()
{
   for(int i = g_TradeCount - 1; i >= 0; i--)
   {
      if(!posInfo.SelectByTicket(g_Trades[i].ticket))
      {
         for(int j = i; j < g_TradeCount - 1; j++)
            g_Trades[j] = g_Trades[j + 1];
         g_TradeCount--;
         ArrayResize(g_Trades, g_TradeCount);
      }
   }
}

